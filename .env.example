# Copy to .env and fill in real values. Never commit .env.
# All vars are prefixed VB_ (pydantic-settings env_prefix).

# ── Telegram ─────────────────────────────────────────────────────────────────
VB_TELEGRAM_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
# Comma-separated Telegram user IDs allowed to send words
VB_ALLOWED_IDS=111111111,222222222
# Optional: numeric ID of the admin user to receive failure alerts
VB_ADMIN_ID=111111111
# Telegram webhook secret (set to a random string; Caddy/nginx forwards the header)
VB_WEBHOOK_SECRET=change-me-random-secret
# Full public base URL where Caddy terminates TLS, e.g. https://bot.example.com
VB_WEBHOOK_BASE_URL=https://bot.example.com

# ── Gemini ────────────────────────────────────────────────────────────────────
# Comma-separated API keys; multiple keys scale concurrency (plan §7)
VB_GEMINI_API_KEYS=key1,key2,key3
# gemini-3.5-flash (default, free tier) or gemini-3.1-pro-preview (paid)
VB_GEMINI_MODEL=gemini-3.5-flash

# ── Azure MAI-Voice-2 (TTS) ───────────────────────────────────────────────────
VB_AZURE_SPEECH_KEY=your-azure-speech-key
VB_AZURE_SPEECH_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# female -> en-US-Harper:MAI-Voice-2 | male -> en-US-Ethan:MAI-Voice-2
VB_VOICE_GENDER=female

# ── AnkiConnect ───────────────────────────────────────────────────────────────
VB_ANKICONNECT_URL=http://anki-headless:8765
VB_TARGET_DECK=Daily
VB_NOTE_TYPE=Eng Vocab 2 Examples

# ── Infrastructure ────────────────────────────────────────────────────────────
VB_DATABASE_URL=sqlite+aiosqlite:///app/data/vocab.db

# ── Observability ─────────────────────────────────────────────────────────────
VB_LOG_LEVEL=INFO
VB_TZ=Asia/Colombo

# ── Headless Anki profile (COPY-PROFILE approach, no in-container login) ──────
# The anki-headless container runs from a vendored copy of
# ThisIsntTheWay/headless-anki in QT_QPA_PLATFORM=offscreen mode. Before first run,
# a local Anki profile must be prepared and COPIED into the anki-headless /data volume
# (the anki-profile named volume in docker-compose.yml):
#
#   1. Log the profile into AnkiWeb on a desktop Anki install (sync once).
#   2. Install the AnkiConnect add-on (code 2055492159).
#   3. In the AnkiConnect config set:
#        webBindAddress: 0.0.0.0
#        webCorsOriginList: ["*"]
#   4. Create the target deck named "Daily".
#   5. Copy the prepared profile folder into the container's /data volume.
#
# No SYNC_USER1 / ANKI_SYNC_USER / ANKI_SYNC_PASS vars exist: personal devices sync to
# AnkiWeb normally; the headless profile syncs to AnkiWeb using its stored credentials.
# To debug with a real GUI surface instead of offscreen, set QT_QPA_PLATFORM=vnc and
# publish port 5900 (see the commented block in docker-compose.yml) — NOT for normal use.
